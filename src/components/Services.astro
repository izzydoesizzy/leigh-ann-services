---
import ServicesIndex, { disciplines, totalServices } from "./ServicesIndex.astro";
const base = import.meta.env.BASE_URL;
---

<!-- Intro strip above the service tiles -->
<section id="services" class="bg-sage text-paper py-20 md:py-24 relative overflow-hidden">
  <div class="hidden md:block absolute left-0 top-1/2 -translate-y-1/2">
    <p class="v-label text-paper/30">Fractional services</p>
  </div>

  <div class="max-w-[1440px] mx-auto px-6 md:px-10">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16 items-end" data-reveal>
      <div class="md:col-span-8">
        <p class="small-caps text-copper mb-4">What I do</p>
        <h2 class="font-display text-5xl md:text-7xl text-paper leading-[0.9] mb-6">
          <span class="tabular">{disciplines.length}</span> disciplines. <span class="italic font-display-italic"><span class="tabular">{totalServices}</span> services.</span>
        </h2>
        <p class="text-paper/70 text-lg leading-relaxed max-w-xl">
          Granular enough to self-diagnose, broad enough to cover the full shape of an executive office. Click any tile below to expand the pain, the outcome, and what's included. Start where the pain is sharpest.
        </p>
      </div>
      <div class="md:col-span-4 md:text-right">
        <a
          href={`${base}services`}
          class="inline-flex items-center gap-3 bg-copper text-paper px-7 py-4 rounded-full text-sm font-medium hover:bg-paper hover:text-ink transition-colors group"
        >
          <span>Open the dedicated page</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>

    <nav class="mt-10 pt-6 border-t border-paper/15 flex flex-wrap gap-x-5 gap-y-2" data-reveal>
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-paper/40 flex-shrink-0">Jump to</span>
      {disciplines.map(d => (
        <a href={`#${d.id}`} class="text-paper/80 text-xs md:text-sm hover:text-copper transition-colors whitespace-nowrap">
          {d.roman}. {d.name}
        </a>
      ))}
    </nav>
  </div>
</section>

<!-- The full compact tile index, inline on the main page -->
<ServicesIndex />
