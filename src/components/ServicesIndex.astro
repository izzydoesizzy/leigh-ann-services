export const totalServices = disciplines.reduce((s, d) => s + d.services.length, 0);
---

{disciplines.map((d, idx) => {
  const useSoft = (idx + altStart) % 2 === 0;
  const sectionBg = useSoft ? "bg-paper-soft" : "bg-paper";
  const isInterludeTarget = beforeId === d.id;
  return (
    <>
      {isInterludeTarget && <slot name="interlude" />}
      <section id={d.id} class={`py-12 md:py-16 ${sectionBg}`}>
      <div class="max-w-6xl mx-auto px-6 md:px-10">
        <!-- Discipline header: compact -->
        <div class="grid md:grid-cols-12 gap-6 mb-10 md:mb-12 pb-6 border-b-2 border-ink">
          <div class="md:col-span-1">
            <span class="font-display text-6xl md:text-7xl text-copper leading-none">{d.roman}.</span>
          </div>
          <div class="md:col-span-7">
            <p class="small-caps text-ink-muted mb-2">Discipline</p>
            <h2 class="font-display text-3xl md:text-5xl text-ink leading-[0.95] mb-3">{d.name}</h2>
            <p class="text-ink-soft text-base md:text-lg leading-relaxed">{d.intro}</p>
          </div>
          <div class="md:col-span-4 md:text-right md:self-end">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-muted">
              <span class="tabular text-copper">{d.services.length}</span> services in this discipline
            </span>
          </div>
        </div>

        <!-- Compact service tiles: click to expand -->
        <div class="grid gap-4 md:gap-5 md:grid-cols-2 lg:grid-cols-3 items-stretch">
          {d.services.map(s => (
            <details class="group bg-paper rounded-sm border border-rule hover:border-copper/40 hover:shadow-md transition-all open:flex open:flex-col h-full">
              <summary class="cursor-pointer p-5 md:p-6 flex items-start justify-between gap-4 list-none">
                <div class="flex-1 min-w-0">
                  <h3 class="font-display text-lg md:text-xl text-ink leading-snug mb-2">{s.name}</h3>
                  <p class="font-display-italic text-sm text-ink-soft leading-snug line-clamp-2 group-open:line-clamp-none transition-all">
                    {s.pain}
                  </p>
                </div>
                <span class="flex-shrink-0 w-8 h-8 rounded-full border border-rule group-hover:border-copper group-hover:bg-copper group-open:bg-copper group-open:border-copper flex items-center justify-center transition-colors">
                  <svg class="w-3.5 h-3.5 text-ink-muted group-hover:text-paper group-open:text-paper group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </span>
              </summary>

              <div class="px-5 md:px-6 pb-5 md:pb-6 pt-5 border-t border-rule/60 flex-1 flex flex-col">
                <p class="small-caps text-copper mb-2">The outcome</p>
                <p class="text-ink text-sm leading-relaxed mb-4">{s.outcome}</p>

                <p class="small-caps text-ink-muted mb-2">Included</p>
                <ul class="space-y-1.5 mb-5">
                  {s.included.slice(0, 4).map(i => (
                    <li class="flex gap-2 items-start text-ink-soft text-sm leading-snug">
                      <span class="font-mono text-[10px] text-copper mt-1.5 flex-shrink-0">&rarr;</span>
                      <span>{i}</span>
                    </li>
                  ))}
                </ul>

                <div class="mt-auto pt-4 border-t border-rule/60 flex flex-wrap items-center justify-between gap-3">
                  <p class="text-ink-muted text-xs leading-snug italic max-w-[14rem]">{s.trigger}</p>
                  <a
                    href={mailto(s.name)}
                    class="inline-flex items-center gap-2 bg-ink text-paper px-4 py-2 rounded-full text-xs font-medium hover:bg-copper transition-colors flex-shrink-0"
                  >
                    <span>Talk to me</span>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                  </a>
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
    </>
  );
})}
