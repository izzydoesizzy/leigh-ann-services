---
// Shared services index: 5 disciplines, 19 services, compact click-to-expand tiles.
// Used on both the /services page and the main index page.

interface Props {
  altStart?: 0 | 1; // control which bg the first discipline takes (to harmonize with neighboring sections)
  beforeId?: string; // render the `interlude` slot immediately before the discipline with this id
}

const { altStart = 0, beforeId } = Astro.props;

const mailto = (topic: string) =>
  `mailto:lmartinlapc@gmail.com?subject=${encodeURIComponent(`Fractional inquiry: ${topic}`)}&body=${encodeURIComponent(`Hi Leigh-Ann,\n\nI'd like to talk about the ${topic} service. Here's what's going on at our executive office:\n\n[describe your situation]\n\nBest,`)}`;

