---
interface Props {
  current: "v1" | "v2" | "v3" | "v4" | "v5";
  theme?: "light" | "dark";
}
const { current, theme = "light" } = Astro.props;
const base = import.meta.env.BASE_URL;

const variants = [
  { id: "v1", href: base, label: "v1 · Editorial" },
  { id: "v2", href: `${base}v2`, label: "v2 · Minimalist" },
  { id: "v3", href: `${base}v3`, label: "v3 · Institutional" },
  { id: "v4", href: `${base}v4`, label: "v4 · Brutalist" },
  { id: "v5", href: `${base}v5`, label: "v5 · Dark luxe" },
];

const bg = theme === "dark" ? "bg-black/80 text-white/90 border-white/15" : "bg-white/90 text-black border-black/10";
const activeBg = theme === "dark" ? "bg-white/15 text-white" : "bg-black text-white";
const inactive = theme === "dark" ? "text-white/60 hover:text-white" : "text-black/60 hover:text-black";
---

<div class={`fixed bottom-4 left-1/2 -translate-x-1/2 z-[100] ${bg} backdrop-blur-md border rounded-full shadow-lg px-2 py-1.5 flex items-center gap-1`}>
  <span class={`text-[10px] uppercase tracking-[0.2em] px-3 hidden sm:inline ${theme === "dark" ? "text-white/40" : "text-black/40"}`}>Preview</span>
  {variants.map(v => (
    <a
      href={v.href}
      class={`text-[11px] font-medium px-3 py-1.5 rounded-full whitespace-nowrap transition-colors ${v.id === current ? activeBg : inactive}`}
    >
      {v.label}
    </a>
  ))}
</div>
