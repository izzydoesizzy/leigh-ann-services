---
const companies = [
  "Ascend Wellness Holdings",
  "Immunovant",
  "Third Bridge",
  "PwC",
  "BearingPoint",
  "Mattio Communications",
];
---

<!-- Trusted-by: editorial styled company names (no logos licensed) -->
<section class="bg-paper py-10 md:py-14 border-b border-rule">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-10" data-reveal>
      <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-ink-muted flex-shrink-0 md:w-48">
        Where I've done the work
      </p>
      <ul class="flex flex-wrap items-center gap-x-8 gap-y-3 md:gap-x-10">
        {companies.map(c => (
          <li class="font-display-italic text-lg md:text-xl text-ink-soft hover:text-ink transition-colors">
            {c}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
