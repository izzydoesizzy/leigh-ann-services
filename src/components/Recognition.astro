---
const features = [
  {
    source: "The New York Times",
    title: "Pop-Up Dinners That Share a Culture, Course by Course",
    date: "January 2020",
  },
  {
    source: "Eater",
    title: "The Uncertain Future of Pop-Up Restaurants",
    date: "May 2020",
  },
  {
    source: "The Washington Post",
    title: "Featured chef and pop-up operator",
    date: "2020",
  },
  {
    source: "Culinary Institute of America",
    title: "Worlds of Flavor International Conference workshop leader",
    date: "Napa Valley",
  },
];

const partners = [
  "Ascend Wellness Holdings",
  "Immunovant",
  "Third Bridge",
  "PwC",
  "Mattio Communications",
  "Kind Kitchen Group (Board)",
];
---

<section class="bg-paper py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="max-w-3xl mb-12 md:mb-16" data-reveal>
      <p class="small-caps text-copper mb-4">Chapter Six</p>
      <h2 class="font-display text-4xl md:text-5xl text-ink leading-[0.95] mb-6">
        In the <span class="italic font-display-italic">press</span>.
      </h2>
      <p class="text-ink-soft text-base md:text-lg leading-relaxed">
        Parallel to my executive career, I've run a nationally recognized pop-up dinner series and published food writing that's been covered in national media. Not directly relevant to board prep, but it's how I learned to handle stakeholders at volume.
      </p>
    </div>

    <!-- Masthead row: big source names -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-rule border-y-2 border-ink" data-reveal>
      {features.map(f => (
        <div class="bg-paper p-8 md:p-10 flex flex-col min-h-[200px]">
          <p class="font-display text-2xl md:text-3xl text-ink leading-tight mb-6">{f.source}</p>
          <p class="text-ink-soft text-sm leading-relaxed mb-auto">{f.title}</p>
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-muted mt-6">{f.date}</p>
        </div>
      ))}
    </div>

    <!-- Worked with list -->
    <div class="mt-16 md:mt-20 grid md:grid-cols-12 gap-8 md:gap-12 items-start border-t border-rule pt-10" data-reveal>
      <div class="md:col-span-4">
        <p class="small-caps text-copper mb-4">Partners and clients</p>
        <p class="font-display text-3xl md:text-4xl text-ink leading-tight">
          Where the <span class="italic font-display-italic">real work</span> got done.
        </p>
      </div>
      <ul class="md:col-span-8 grid sm:grid-cols-2 gap-x-8 gap-y-3">
        {partners.map(p => (
          <li class="flex gap-3 items-baseline border-b border-rule/50 pb-3">
            <span class="font-mono text-[10px] text-copper tabular">●</span>
            <span class="text-ink text-base md:text-lg font-medium">{p}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
