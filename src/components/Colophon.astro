---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="bg-ink text-paper pt-20 pb-10">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10">
    <div class="grid md:grid-cols-12 gap-10 md:gap-16 pb-16 border-b border-paper/10">
      <!-- Large wordmark -->
      <div class="md:col-span-5">
        <p class="small-caps text-paper/40 mb-6">Leigh-Ann Martin</p>
        <p class="font-display text-5xl md:text-6xl text-paper leading-[0.92] mb-6">
          A strategic partner, not an assistant.
        </p>
        <p class="text-paper/50 text-sm leading-relaxed max-w-sm">
          Senior executive support for leaders who need anticipation, discretion, and operational rigor, without a traditional org chart.
        </p>
      </div>

      <!-- Links -->
      <div class="md:col-span-3 md:col-start-7">
        <p class="small-caps text-paper/40 mb-4">Navigate</p>
        <ul class="space-y-2.5 text-paper/70 text-sm">
          <li><a href="#two-paths" class="hover:text-copper transition-colors">Two paths</a></li>
          <li><a href="#work" class="hover:text-copper transition-colors">Selected work</a></li>
          <li><a href="#services" class="hover:text-copper transition-colors">Services</a></li>
          <li><a href="#about" class="hover:text-copper transition-colors">About</a></li>
          <li><a href="#contact" class="hover:text-copper transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-3">
        <p class="small-caps text-paper/40 mb-4">Reach out</p>
        <ul class="space-y-2.5 text-paper/70 text-sm">
          <li><a href="mailto:lmartinlapc@gmail.com" class="hover:text-copper transition-colors">lmartinlapc@gmail.com</a></li>
          <li><a href="https://www.linkedin.com/in/leigh-ann-martin" target="_blank" rel="noopener" class="hover:text-copper transition-colors">LinkedIn</a></li>
          <li><span class="text-paper/50">Based in New York (tri-state area)</span></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-paper/40 text-xs tabular">&copy; {year} Leigh-Ann Martin. All rights reserved.</p>
      <p class="small-caps text-paper/30">Set in Fraunces &amp; Inter</p>
    </div>
  </div>
</footer>
