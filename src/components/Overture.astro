---
const base = import.meta.env.BASE_URL;

// TODO: swap to Leigh-Ann's real Calendly URL
const CALENDLY_URL = "https://calendly.com/lmartinlapc/intro-call";

const stats = [
  { value: "12+", label: "years supporting C-suite" },
  { value: "200+", label: "stakeholders coordinated" },
  { value: "98%", label: "stakeholder satisfaction" },
  { value: "25%", label: "operational efficiency lift" },
];
---

<!-- Hero / Overture: pain-led headline with portrait, anchors the whole case for hiring -->
<section class="relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 md:px-10 pt-10 md:pt-16 pb-12 md:pb-20">
    <!-- Issue heading -->
    <div class="flex items-baseline justify-between mb-8 md:mb-12" data-reveal>
      <div class="flex items-baseline gap-4 md:gap-6">
        <span class="small-caps text-ink-muted">Vol. I</span>
        <span class="hidden md:inline text-ink-muted font-mono text-[11px]">&middot;</span>
        <span class="hidden md:inline small-caps text-ink-muted">Executive support, reimagined</span>
      </div>
      <span class="small-caps text-ink-muted tabular">2026</span>
    </div>

    <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-end">
      <!-- Left: pain-led display headline -->
      <div class="md:col-span-7" data-reveal>
        <p class="small-caps text-copper mb-5">The Dossier</p>
        <h1 class="font-display text-[8vw] md:text-[4.5rem] lg:text-[5.5rem] text-ink leading-[0.95] tracking-[-0.03em]">
          The executive office
          <br/>should run on
          <span class="italic font-display-italic text-copper">systems</span>,
          <br/>not heroics.
        </h1>

        <p class="mt-8 md:mt-10 text-lg md:text-xl text-ink-soft leading-relaxed max-w-xl">
          If board prep is a quarterly fire drill, if earnings coordination lives in someone's head, if your EA function was built for the company you were two funding rounds ago, we should talk. Twelve years rebuilding board cadence, investor-relations coordination, and the EA function itself, for pre-IPO biotech, public-company cannabis, and Big Four.
        </p>

        <div class="mt-8 md:mt-10 flex flex-col sm:flex-row gap-3">
          <a
            href={CALENDLY_URL}
            target="_blank"
            rel="noopener"
            class="group inline-flex items-center justify-center gap-3 bg-ink text-paper px-7 py-4 rounded-full text-sm font-medium hover:bg-copper transition-colors"
          >
            <span>Book a 20-minute intro call</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
          <a
            href={`${base}capability-brief`}
            class="group inline-flex items-center justify-center gap-3 text-ink px-5 py-4 text-sm font-medium hover:text-copper transition-colors"
          >
            <span>Read the capability brief</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
        </div>

        <!-- Capacity signal -->
        <p class="mt-6 font-mono text-[11px] uppercase tracking-[0.2em] text-ink-muted">
          <span class="text-copper">&#x25CF;</span> Booking for Q2 2026 &middot; 2 of 3 slots remain &middot; Q3 availability opens June 15
        </p>
      </div>

      <!-- Right: portrait + caption block -->
      <div class="md:col-span-5" data-reveal>
        <figure class="relative">
          <div class="aspect-[3/4] rounded-[2px] overflow-hidden bg-paper-deep shadow-[0_20px_60px_-20px_rgba(22,21,19,0.25)]">
            <img
              src={`${base}portrait.jpg`}
              alt="Leigh-Ann Martin"
              class="w-full h-full object-cover"
              style="object-position: center top;"
            />
          </div>
          <!-- Caption with editorial rule -->
          <figcaption class="mt-4 pt-3 border-t border-ink/20">
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-muted mb-1">Portrait</p>
            <p class="font-caption text-sm text-ink-soft italic leading-snug">
              Leigh-Ann Martin, New York, 2026. Fractional partner to the executive office. Twelve years as a senior EA before this. Chef by training, New York Times-covered pop-up operator.
            </p>
          </figcaption>

          <!-- Floating availability badge. TODO: update slot count + quarter as availability changes. -->
          <div class="absolute -left-4 md:-left-8 top-6 bg-copper text-paper px-3 py-2 rotate-[-4deg] shadow-lg max-w-[180px]">
            <span class="small-caps text-paper leading-tight block">2 slots &middot; Q2 2026</span>
            <span class="font-mono text-[9px] uppercase tracking-wider text-paper/80 block mt-0.5">Booking now</span>
          </div>
        </figure>
      </div>
    </div>

    <!-- Lower strip: resume-backed stats -->
    <div class="mt-12 md:mt-16 pt-8 border-t border-rule" data-reveal>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-10">
        {stats.map((s, idx) => (
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-copper mb-2 tabular">0{idx + 1}</p>
            <p class="font-display text-4xl md:text-5xl text-ink leading-none tabular mb-2">{s.value}</p>
            <p class="text-ink-muted text-xs md:text-sm leading-snug">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
