---
// Featured testimonial: Pam Connealy's live LinkedIn recommendation.
// Plus a few shorter stakeholder quotes pulled from intake notes.

const featured = {
  author: "Pam Connealy",
  title: "Former CFO and COO",
  company: "Immunovant",
  quote: "I worked alongside Leigh-Ann for several years at Immunovant, and she was one of the most reliable operational partners I've had. As CFO and later COO, I depended on precise coordination for board materials, quarterly reporting, and investor communications. Leigh-Ann enhanced our reporting accuracy by 25% by utilizing advanced analytics tools to translate executive vision into actionable operational initiatives. She partnered across HR, Facilities, and our Executive Leadership Team to modernize policies and implement hybrid work frameworks that improved employee satisfaction scores by 22%. She also designed and executed onboarding programs for 6 administrative professionals, reducing ramp-up time by 20%. What impressed me most was her financial literacy. She didn't just move documents around. She understood what was in them, flagged issues before they became problems, and brought structured problem-solving to high-level executive operations. Any executive team would be lucky to have her.",
  status: "Live on LinkedIn",
};

const shorter = [
  {
    text: "Lovely to work with, responsive, knew what I was doing. Not being reactionary, took action.",
    author: "CFO review, Immunovant",
  },
  {
    text: "She is constantly asking questions to create a better system. Constantly thinking about processes.",
    author: "Ascend leader reference",
  },
  {
    text: "Extremely accommodating and reasonable.",
    author: "Mattio Communications external partner",
  },
];
---

<section class="bg-ink text-paper py-16 md:py-24 relative">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="max-w-3xl mb-12 md:mb-16" data-reveal>
      <p class="small-caps text-copper mb-4">Chapter Seven</p>
      <h2 class="font-display text-4xl md:text-5xl text-paper leading-[0.95]">
        From those who <span class="italic font-display-italic">worked with me</span>.
      </h2>
    </div>

    <!-- Featured quote -->
    <figure class="max-w-3xl mb-14 md:mb-16" data-reveal>
      <span class="block font-display text-8xl md:text-[10rem] text-copper leading-none -mb-6 md:-mb-8">"</span>
      <blockquote class="font-display text-xl md:text-2xl lg:text-[1.9rem] text-paper leading-[1.3] mb-6 md:mb-8">
        {featured.quote}
      </blockquote>
      <figcaption class="flex items-center gap-4 pt-6 border-t border-paper/10">
        <div class="flex-1">
          <p class="font-display text-xl text-paper">{featured.author}</p>
          <p class="text-paper/50 text-sm mt-1">{featured.title}, {featured.company}</p>
        </div>
        <span class="small-caps bg-copper text-ink px-3 py-1.5 rounded-full">{featured.status}</span>
      </figcaption>
    </figure>

    <!-- Shorter quotes -->
    <div class="grid md:grid-cols-3 gap-8 md:gap-12 pt-10 border-t border-paper/10" data-reveal>
      {shorter.map(s => (
        <figure>
          <blockquote class="font-display-italic text-xl md:text-2xl text-paper/90 leading-snug mb-4">
            "{s.text}"
          </blockquote>
          <figcaption class="font-mono text-[10px] uppercase tracking-[0.2em] text-paper/40">
            {s.author}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
