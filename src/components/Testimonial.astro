---
// Shorter stakeholder quotes pulled from intake notes.
// Pam Connealy's full LinkedIn recommendation lives in PamQuote.astro near the hero.

const shorter = [
  {
    text: "Lovely to work with, responsive, knew what I was doing. Not being reactionary, took action.",
    author: "CFO review, Immunovant",
  },
  {
    text: "Extremely accommodating and reasonable.",
    author: "Mattio Communications, external IR partner",
  },
];
---

<section class="bg-ink text-paper py-16 md:py-24 relative">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="max-w-3xl mb-10 md:mb-14" data-reveal>
      <p class="small-caps text-copper mb-4">Chapter Seven</p>
      <h2 class="font-display text-4xl md:text-5xl text-paper leading-[0.95]">
        From those who <span class="italic font-display-italic">worked with me</span>.
      </h2>
      <p class="mt-5 text-paper/65 text-base md:text-lg leading-relaxed">
        Short notes from the executives and partners who ran alongside me. Pam Connealy's full recommendation is at the top of the page; the Ascend reference sits mid-page after the case studies.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12 pt-10 border-t border-paper/10 max-w-4xl" data-reveal>
      {shorter.map(s => (
        <figure>
          <blockquote class="font-display-italic text-xl md:text-2xl text-paper/90 leading-snug mb-4">
            "{s.text}"
          </blockquote>
          <figcaption class="font-mono text-[10px] uppercase tracking-[0.2em] text-paper/40">
            {s.author}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
