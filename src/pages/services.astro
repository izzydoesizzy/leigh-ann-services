---
import Layout from "../layouts/Layout.astro";
import Masthead from "../components/Masthead.astro";
import Colophon from "../components/Colophon.astro";
import ServicesIndex, { disciplines, totalServices } from "../components/ServicesIndex.astro";
---

<Layout title="Services | Leigh-Ann Martin" description="Every granular fractional EA service Leigh-Ann Martin offers, organized by discipline. Board cadence, investor relations, FDA coordination, EA function build-out, and more.">
  <Masthead />
  <main>
    <!-- Hero -->
    <section class="pt-20 md:pt-16 pb-10 md:pb-14 bg-paper">
      <div class="max-w-6xl mx-auto px-6 md:px-10">
        <div class="flex items-baseline justify-between mb-8" data-reveal>
          <div class="flex items-baseline gap-6">
            <span class="small-caps text-ink-muted">Vol. I</span>
            <span class="hidden md:inline small-caps text-ink-muted">The service index</span>
          </div>
          <span class="small-caps text-ink-muted tabular">2026</span>
        </div>

        <div class="grid md:grid-cols-12 gap-8 items-end" data-reveal>
          <div class="md:col-span-8">
            <p class="small-caps text-copper mb-5">Every service</p>
            <h1 class="font-display text-[8vw] md:text-[4.5rem] lg:text-[5.5rem] text-ink leading-[0.95] tracking-[-0.03em]">
              Pick the <span class="italic font-display-italic text-copper">pain</span>.
              <br/>Start there.
            </h1>
          </div>
          <div class="md:col-span-4">
            <p class="text-ink-soft text-base md:text-lg leading-relaxed">
              <span class="font-display text-copper tabular">{totalServices} services</span>, organized into <span class="font-display text-copper tabular">{disciplines.length} disciplines</span>. Each one named after a specific pain, scoped against a specific outcome. Click a tile to expand.
            </p>
            <p class="mt-4 font-mono text-[11px] uppercase tracking-wider text-ink-muted">
              No prices on this page. Pricing is conversation-first, always.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Jump nav: sticky under masthead -->
    <nav class="sticky top-14 z-40 bg-paper/90 backdrop-blur-md border-y border-rule py-3" data-reveal>
      <div class="max-w-6xl mx-auto px-6 md:px-10 flex flex-wrap items-center gap-x-5 gap-y-2">
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-muted flex-shrink-0">Jump to</span>
        {disciplines.map(d => (
          <a href={`#${d.id}`} class="text-ink text-xs md:text-sm hover:text-copper transition-colors whitespace-nowrap">
            {d.roman}. {d.name}
          </a>
        ))}
      </div>
    </nav>

    <!-- Disciplines + tiles -->
    <ServicesIndex />

    <!-- Closing CTA -->
    <section class="bg-ink text-paper py-16 md:py-24">
      <div class="max-w-3xl mx-auto px-6 md:px-10 text-center" data-reveal>
        <p class="small-caps text-copper mb-5">Ready to talk</p>
        <h2 class="font-display text-4xl md:text-5xl text-paper leading-[0.95] mb-6">
          Tell me what's <span class="italic font-display-italic">actually</span> breaking.
        </h2>
        <p class="text-paper/70 text-base md:text-lg leading-relaxed mb-8">
          A 20-minute intro call, free, usually inside 48 hours of your first reach-out. Even if we don't end up working together, you'll leave with a clearer picture of what's worth fixing first.
        </p>
        <a
          href="https://calendly.com/lmartinlapc/intro-call"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 bg-copper text-paper px-7 py-4 rounded-full text-sm font-medium hover:bg-paper hover:text-ink transition-colors group"
        >
          <span>Book a 20-minute intro call</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </section>
  </main>
  <Colophon />
</Layout>

<script>
  const revealEls = document.querySelectorAll("[data-reveal]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05, rootMargin: "0px 0px -40px 0px" }
  );
  revealEls.forEach((el) => observer.observe(el));
</script>
