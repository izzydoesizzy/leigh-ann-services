---
import Layout from "../layouts/Layout.astro";
import { disciplines, totalServices } from "../components/ServicesIndex.astro";
import { pullQuotes } from "../data/pull-quotes.ts";

// Brief-friendly subset: print-first rhythm, 6 pulls total.
const briefPamFeature = pullQuotes.find(q => q.extract.startsWith("She didn't just move"))!;
const briefPamCloser = pullQuotes.find(q => q.extract === "Any executive team would be lucky to have her.")!;
const briefJulia = pullQuotes.find(q => q.extract.startsWith("She operated as a true"))!;
const briefCourtney = pullQuotes.find(q => q.extract.startsWith("Working with her made"))!;
const briefShorts = [
  pullQuotes.find(q => q.extract.startsWith("In a fast-moving")),
  pullQuotes.find(q => q.extract.startsWith("You could hand")),
  pullQuotes.find(q => q.extract === "What stood out most was her judgment."),
  pullQuotes.find(q => q.extract === "She operates at the highest level."),
  pullQuotes.find(q => q.extract.startsWith("Cannabis is a volatile")),
].filter(Boolean) as typeof pullQuotes;

const base = import.meta.env.BASE_URL;
const CALENDLY_URL = "https://calendly.com/leighannmartin/30min";

const stats = [
  { value: "12+", label: "years supporting C-suite", sub: "PwC, Third Bridge, Immunovant, Ascend" },
  { value: "5", label: "C-suite execs as sole EA", sub: "Immunovant, by March 2020" },
  { value: "200+", label: "stakeholders coordinated", sub: "across 7 markets at Ascend" },
  { value: "98%", label: "stakeholder satisfaction", sub: "C-suite, board, and IR partners" },
  { value: "25%", label: "operational efficiency lift", sub: "M&A, IR, and ELT alignment" },
  { value: "22%", label: "employee satisfaction lift", sub: "hybrid work and policy modernization" },
  { value: "20%", label: "faster EA onboarding", sub: "scalable training frameworks" },
  { value: "$10M+", label: "monthly processing", sub: "100% regulatory compliance" },
];

const cases = [
  {
    num: "01",
    company: "Ascend Wellness Holdings",
    role: "EA to the CEO and President",
    headline: "Board cadence from zero.",
    body: "When I arrived there were no board meetings on the calendar. I coordinated an 8-person quarterly board convening (4 external directors plus CEO, CFO, President, and Chief Counsel) and two standing committees (Audit and Compensation). Anchored dates against earnings and legal review windows, and locked in member availability 12 months ahead.",
    metrics: [
      { label: "months planned ahead", value: "12" },
      { label: "standing committees", value: "2" },
      { label: "board convening", value: "8-person" },
    ],
  },
  {
    num: "02",
    company: "Immunovant",
    role: "Senior EA to CEO and General Counsel",
    headline: "The EA function, from zero.",
    body: "Employee #17 at hire. Built the EA function from scratch as Immunovant scaled. Sole EA for five C-suite executives by March 2020. Designed onboarding programs for 6 administrative professionals that reduced ramp-up time by 20%. Co-founded the Culture Committee with HR and partnered with Facilities and ELT on policies that lifted employee satisfaction by 22%.",
    metrics: [
      { label: "C-suite execs as sole EA", value: "5" },
      { label: "faster new-hire ramp", value: "20%" },
      { label: "employee satisfaction lift", value: "22%" },
    ],
  },
  {
    num: "03",
    company: "Ascend Wellness Holdings",
    role: "EA, Investor Relations",
    headline: "Earnings prep, rebuilt.",
    body: "One cycle in-role exposed the gaps. July 2025, I rebuilt the system. Aligned external IR (Mattio Communications), Legal, VP Financial Planning, PR, and C-suite on a shared 6 to 8 week cadence with SharePoint template discipline. Granted the Chief Commercial Officer script access mid-cycle and pulled the VP of Marketing into live prep, closing the input loops that had forced post-draft revisions. Deployed for Q2 2025 and ran through my tenure.",
    metrics: [
      { label: "week system", value: "6 to 8" },
      { label: "stakeholder satisfaction", value: "98%" },
      { label: "efficiency improvement", value: "25%" },
    ],
  },
];

const process = [
  { num: "01", phase: "Discovery", time: "Free, 30 minutes", title: "Tell me what's breaking.", body: "A short call, usually inside 48 hours of your reach-out. You describe the real pain, I ask the questions I need to scope a fit." },
  { num: "02", phase: "Written scope", time: "2 business days", title: "I write back with the shape.", body: "A written scope with the specific outcome, deliverables, milestones, timeline, and investment. Flat-priced against the outcome, not hourly." },
  { num: "03", phase: "Kickoff + audit", time: "Week 1", title: "I embed enough to see the real state.", body: "Discovery calls with 3 to 5 stakeholders. A pass through your systems. A written diagnostic by end of week one." },
  { num: "04", phase: "Delivery cadence", time: "Weeks 2 through N", title: "Working sessions, async between.", body: "Weekly 45 to 60 minute live session. Async Friday progress memos. Your preferred comms tool for questions between. I build in your systems so the work survives my handoff." },
  { num: "05", phase: "Handoff", time: "Final week", title: "You own it. I step back.", body: "Complete documentation, a recorded walkthrough for whoever runs it after me, and an optional 30-day check-in at no charge. Breaks in the first 90 days, I fix it on my time." },
];

const credentials = [
  {
    kind: "Professional",
    name: "Certified Administrative Professional",
    detail: "CAP &middot; International Association of Administrative Professionals",
  },
  {
    kind: "Platform",
    name: "Salesforce Certified Platform Administrator",
    detail: "Salesforce, current",
  },
  {
    kind: "Platform",
    name: "Microsoft Office Certified Specialist",
    detail: "Microsoft, certified",
  },
  {
    kind: "Professional",
    name: "Strategic Project Management",
    detail: "In progress",
  },
  {
    kind: "Education",
    name: "B.S. Business Administration",
    detail: "SBCS Global Learning Institute, Trinidad and Tobago",
  },
  {
    kind: "Education",
    name: "Institute of Culinary Education",
    detail: "Culinary Arts, Highest Honors",
  },
];

const press = [
  { source: "The New York Times", title: "Pop-Up Dinners That Share a Culture, Course by Course", date: "January 2020" },
  { source: "Eater", title: "The Uncertain Future of Pop-Up Restaurants", date: "May 2020" },
  { source: "The Washington Post", title: "Featured chef and pop-up operator", date: "2020" },
  { source: "Culinary Institute of America", title: "Worlds of Flavor International Conference workshop leader", date: "Napa Valley" },
];
---

<Layout title="Capability Brief | Leigh-Ann Martin" bodyClass="paper-grain antialiased brief-doc">
  <!-- Sticky action bar (screen only) -->
  <div class="sticky top-0 z-50 bg-ink text-paper border-b border-paper/10 print:hidden">
    <div class="max-w-6xl mx-auto px-6 md:px-10 py-3 flex items-center justify-between gap-4">
      <div class="flex items-baseline gap-3">
        <a href={base} class="font-mono text-[10px] uppercase tracking-[0.25em] text-paper/60 hover:text-copper transition-colors">&larr; Main site</a>
        <span class="hidden md:inline font-mono text-[10px] uppercase tracking-[0.25em] text-paper/30">|</span>
        <span class="hidden md:inline small-caps text-paper/70">Capability Brief, 2026</span>
      </div>
      <div class="flex items-center gap-3">
        <button
          id="print-btn"
          class="inline-flex items-center gap-2 bg-copper text-paper px-4 py-2 rounded-full text-xs font-medium hover:bg-paper hover:text-ink transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
          <span>Save as PDF</span>
        </button>
        <a
          href={CALENDLY_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-paper text-ink px-4 py-2 rounded-full text-xs font-medium hover:bg-copper hover:text-paper transition-colors"
        >
          <span>Book intro call</span>
        </a>
      </div>
    </div>
  </div>

  <main class="bg-paper">
    <!-- Cover -->
    <section class="brief-page min-h-screen flex flex-col justify-between py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-6 md:px-10 w-full">
        <div class="flex items-baseline justify-between mb-16">
          <span class="small-caps text-ink-muted">Capability Brief</span>
          <span class="font-mono text-[11px] uppercase tracking-[0.25em] text-ink-muted">Edition 2026</span>
        </div>

        <div class="grid md:grid-cols-12 gap-10 md:gap-16 items-end">
          <div class="md:col-span-8">
            <p class="small-caps text-copper mb-6">For the executive office that deserves better.</p>
            <h1 class="font-display text-5xl md:text-7xl lg:text-[5.5rem] text-ink leading-[0.95] tracking-[-0.03em] mb-10">
              Leigh-Ann <span class="italic font-display-italic text-copper">Martin</span>.
            </h1>
            <p class="text-xl md:text-2xl text-ink-soft leading-snug max-w-xl mb-8">
              Senior Executive Assistant. Fractional partner. Twelve years running the operational layer beneath C-suite leaders.
            </p>
            <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-muted">
              Board cadence &middot; Earnings coordination &middot; EA function build-out
            </p>
          </div>
          <div class="md:col-span-4">
            <figure>
              <div class="aspect-[3/4] rounded-[2px] overflow-hidden bg-paper-deep shadow-[0_20px_60px_-20px_rgba(22,21,19,0.25)] print:shadow-none">
                <img
                  src={`${base}portrait.jpg`}
                  alt="Leigh-Ann Martin"
                  class="w-full h-full object-cover"
                  style="object-position: center top;"
                />
              </div>
              <figcaption class="mt-3 font-caption text-xs text-ink-muted italic">
                New York, 2026.
              </figcaption>
            </figure>
          </div>
        </div>
      </div>

      <div class="max-w-5xl mx-auto px-6 md:px-10 w-full mt-16">
        <div class="flex items-baseline justify-between pt-6 border-t border-ink">
          <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-ink-muted">lmartinlapc@gmail.com &middot; linkedin.com/in/leigh-ann-martin</p>
          <p class="font-display-italic text-ink">vol. I</p>
        </div>
      </div>
    </section>

    <!-- Table of contents -->
    <section class="brief-page bg-paper-soft py-16 md:py-20 border-y border-rule">
      <div class="max-w-5xl mx-auto px-6 md:px-10">
        <p class="small-caps text-copper mb-5">Contents</p>
        <h2 class="font-display text-3xl md:text-4xl text-ink leading-[0.95] mb-10">What's in this brief.</h2>
        <ol class="grid sm:grid-cols-2 gap-x-10 gap-y-3 text-ink">
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">I. About</span><span class="font-mono text-xs text-ink-muted tabular">p. 03</span></li>
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">II. By the numbers</span><span class="font-mono text-xs text-ink-muted tabular">p. 04</span></li>
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">III. Selected work</span><span class="font-mono text-xs text-ink-muted tabular">p. 05</span></li>
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">IV. How clients describe me</span><span class="font-mono text-xs text-ink-muted tabular">p. 07</span></li>
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">V. The full services catalog</span><span class="font-mono text-xs text-ink-muted tabular">p. 08</span></li>
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">VI. How I work</span><span class="font-mono text-xs text-ink-muted tabular">p. 12</span></li>
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">VII. Engagement shapes</span><span class="font-mono text-xs text-ink-muted tabular">p. 13</span></li>
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">VIII. Credentials</span><span class="font-mono text-xs text-ink-muted tabular">p. 14</span></li>
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">IX. In the press</span><span class="font-mono text-xs text-ink-muted tabular">p. 15</span></li>
          <li class="flex items-baseline justify-between gap-4 border-b border-rule/50 pb-2"><span class="font-display text-lg">X. Next steps</span><span class="font-mono text-xs text-ink-muted tabular">p. 16</span></li>
        </ol>
      </div>
    </section>

    <!-- I. About -->
    <section class="brief-page py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-6 md:px-10">
        <div class="flex items-baseline gap-6 mb-10">
          <span class="font-display text-6xl text-copper leading-none">I.</span>
          <div>
            <p class="small-caps text-copper mb-1">Chapter One</p>
            <h2 class="font-display text-3xl md:text-4xl text-ink leading-[0.95]">About.</h2>
          </div>
        </div>

        <div class="grid md:grid-cols-12 gap-10">
          <div class="md:col-span-8 space-y-5 text-ink text-lg leading-relaxed">
            <p>
              I grew up in Gasparillo, Trinidad, and my first job at 18 was at Petrotrin, the national oil company, in the Office of the VP of Oil and Refining. I moved to New York in 2006 and have been working in executive offices ever since. BearingPoint through PwC, Third Bridge, Immunovant, and Ascend Wellness Holdings. I was sole EA to five C-suite executives at pre-IPO Immunovant by March 2020. I built Ascend's quarterly board cadence from zero.
            </p>
            <p>
              Parallel to my corporate career, I trained as a chef at the Institute of Culinary Education with highest honors and built <em>A Table For Four</em>, a pop-up dinner series that ran in New York, London, Wisconsin, and Grenada and was covered by <em>The New York Times</em>, <em>Eater</em>, and <em>The Washington Post</em>. That work taught me how to curate, host, and operate at volume. The two careers have always informed each other.
            </p>
            <p>
              My approach is simple. Anticipate, don't react. Take ownership, don't just execute. Build systems that survive transitions. Treat confidentiality as default, not a policy. I work with Claude and Perplexity daily, hold my Certified Administrative Professional credential, and I'm Salesforce Certified Platform Administrator. I'd like to work with executives who value that, embedded or fractional.
            </p>
          </div>

          <aside class="md:col-span-4 md:border-l md:border-rule md:pl-8">
            <p class="small-caps text-copper mb-5">At a glance</p>
            <dl class="space-y-5">
              <div>
                <dt class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-muted mb-1">Based</dt>
                <dd class="text-ink text-base leading-snug">Union City, NJ &middot; NYC tri-state</dd>
              </div>
              <div>
                <dt class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-muted mb-1">Open to</dt>
                <dd class="text-ink text-base leading-snug">Hybrid or in-office senior EA roles in NYC. Fully remote fractional engagements.</dd>
              </div>
              <div>
                <dt class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-muted mb-1">Sectors</dt>
                <dd class="text-ink text-base leading-snug">Biotech, biopharma, finance, fintech, public-company operations</dd>
              </div>
              <div>
                <dt class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-muted mb-1">Board work</dt>
                <dd class="text-ink text-base leading-snug">Board Member, Kind Kitchen Group</dd>
              </div>
              <div>
                <dt class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-muted mb-1">Languages</dt>
                <dd class="text-ink text-base leading-snug">English (native) &middot; Trinidadian Creole (native)</dd>
              </div>
            </dl>
          </aside>
        </div>
      </div>
    </section>

    <!-- II. By the numbers -->
    <section class="brief-page bg-paper-deep py-16 md:py-20 border-y border-rule">
      <div class="max-w-5xl mx-auto px-6 md:px-10">
        <div class="flex items-baseline gap-6 mb-10">
          <span class="font-display text-6xl text-copper leading-none">II.</span>
          <div>
            <p class="small-caps text-copper mb-1">Chapter Two</p>
            <h2 class="font-display text-3xl md:text-4xl text-ink leading-[0.95]">By the numbers.</h2>
          </div>
        </div>

        <p class="text-ink-soft text-base md:text-lg leading-relaxed max-w-2xl mb-10">
          Resume-backed metrics. Every figure is attested to in the career documents my references would confirm.
        </p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-rule border border-rule">
          {stats.map((s, idx) => (
            <div class="bg-paper-deep p-5 md:p-6 flex flex-col">
              <span class="font-mono text-[10px] uppercase tracking-[0.25em] text-ink-muted mb-3 tabular">0{idx + 1}</span>
              <span class="font-display text-4xl md:text-5xl text-ink leading-none tabular mb-3">{s.value}</span>
              <span class="text-ink text-sm font-medium mb-1 leading-snug">{s.label}</span>
              <span class="text-ink-muted text-xs leading-relaxed mt-auto">{s.sub}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- III. Selected work -->
    <section class="brief-page py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-6 md:px-10">
        <div class="flex items-baseline gap-6 mb-10">
          <span class="font-display text-6xl text-copper leading-none">III.</span>
          <div>
            <p class="small-caps text-copper mb-1">Chapter Three</p>
            <h2 class="font-display text-3xl md:text-4xl text-ink leading-[0.95]">Selected work.</h2>
          </div>
        </div>

        <div class="space-y-14">
          {cases.map(c => (
            <article class="grid md:grid-cols-12 gap-6 md:gap-10">
              <div class="md:col-span-7">
                <div class="border-t-2 border-ink pt-4 mb-5">
                  <p class="small-caps text-copper">{c.company}</p>
                  <p class="font-mono text-[10px] uppercase tracking-wider text-ink-muted mt-1">{c.role}</p>
                </div>
                <h3 class="font-display text-2xl md:text-3xl text-ink leading-[1.05] mb-4">{c.headline}</h3>
                <p class="text-ink-soft leading-relaxed text-base">{c.body}</p>
              </div>
              <div class="md:col-span-5 md:pl-8 md:border-l md:border-rule">
                <p class="small-caps text-ink-muted mb-5">By the numbers</p>
                <dl class="space-y-4">
                  {c.metrics.map(m => (
                    <div>
                      <dt class="font-mono text-[10px] text-ink-muted uppercase tracking-[0.2em] mb-1">{m.label}</dt>
                      <dd class="font-display text-3xl text-copper leading-none tabular">{m.value}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- IV. Testimonials: pull-quote wall -->
    <section class="brief-page bg-ink text-paper py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-6 md:px-10">
        <div class="flex items-baseline gap-6 mb-10">
          <span class="font-display text-6xl text-copper leading-none">IV.</span>
          <div>
            <p class="small-caps text-copper mb-1">Chapter Four</p>
            <h2 class="font-display text-3xl md:text-4xl text-paper leading-[0.95]">How clients describe me.</h2>
          </div>
        </div>

        <p class="text-paper/65 text-sm md:text-base leading-relaxed max-w-2xl mb-4">
          Extracts from recommendations by former CEOs, CFOs, Chairmen, and external partners across clinical-stage biotech, public-company cannabis, and external IR.
        </p>
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-paper/40 leading-relaxed mb-10">
          Pam Connealy is live on LinkedIn. Others are drafts pending approval, anonymized by role and sector.
        </p>

        <!-- Pam feature pull -->
        <figure class="mb-12 pb-10 border-b border-paper/15">
          <span class="block font-display text-6xl md:text-8xl text-copper leading-none -mb-4 md:-mb-6">"</span>
          <blockquote class="font-display text-2xl md:text-3xl text-paper leading-[1.2]">
            {briefPamFeature.extract}
          </blockquote>
          <figcaption class="mt-6 flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <p class="font-display text-base text-paper">{briefPamFeature.role}</p>
            <span class="text-paper/40 text-xs">&middot;</span>
            <p class="text-paper/55 text-sm">{briefPamFeature.sector}</p>
            <span class="ml-auto small-caps bg-copper text-ink px-3 py-1 rounded-full text-[10px]">Live on LinkedIn</span>
          </figcaption>
        </figure>

        <!-- Julia + Courtney large anonymized pulls -->
        <div class="grid md:grid-cols-2 gap-10 mb-12">
          <figure>
            <blockquote class="font-display-italic text-xl md:text-2xl text-paper leading-snug mb-4 border-l-2 border-copper pl-5">
              "{briefJulia.extract}"
            </blockquote>
            <figcaption class="pl-5 flex flex-wrap items-baseline gap-x-2">
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-paper/50">{briefJulia.role}</span>
              <span class="text-paper/30 text-xs">&middot;</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-paper/40">{briefJulia.sector}</span>
            </figcaption>
          </figure>
          <figure>
            <blockquote class="font-display-italic text-xl md:text-2xl text-paper leading-snug mb-4 border-l-2 border-copper pl-5">
              "{briefCourtney.extract}"
            </blockquote>
            <figcaption class="pl-5 flex flex-wrap items-baseline gap-x-2">
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-paper/50">{briefCourtney.role}</span>
              <span class="text-paper/30 text-xs">&middot;</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-paper/40">{briefCourtney.sector}</span>
            </figcaption>
          </figure>
        </div>

        <!-- Shorter voices -->
        <div class="grid md:grid-cols-3 gap-8 pt-10 border-t border-paper/15 mb-10">
          {briefShorts.slice(0, 3).map(q => (
            <figure>
              <blockquote class="font-display-italic text-base md:text-lg text-paper/90 leading-snug mb-3">"{q.extract}"</blockquote>
              <figcaption class="font-mono text-[9px] uppercase tracking-[0.2em] text-paper/40">{q.role} &middot; {q.sector}</figcaption>
            </figure>
          ))}
        </div>

        <!-- Closer -->
        <div class="pt-10 border-t border-paper/15 text-center">
          <p class="font-display-italic text-xl md:text-2xl text-paper leading-snug max-w-2xl mx-auto">
            "{briefPamCloser.extract}"
          </p>
          <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.25em] text-paper/40">
            {briefPamCloser.role} &middot; {briefPamCloser.sector}
          </p>
        </div>
      </div>
    </section>

    <!-- V. Full services catalog -->
    <section class="brief-page py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-6 md:px-10">
        <div class="flex items-baseline gap-6 mb-10">
